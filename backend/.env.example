# Copy to .env and fill in values

# Postgres on Neon (https://neon.tech — free tier)
# Get the connection string from your Neon project dashboard and replace postgresql:// with postgresql+psycopg://
DATABASE_URL=postgresql+psycopg://user:pass@host.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173
